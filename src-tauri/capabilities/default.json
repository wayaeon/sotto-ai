{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability for the overlay window",
  "windows": ["main", "pill"],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "shell:allow-execute",
    "shell:allow-open",
    "sql:default"
  ]
}
