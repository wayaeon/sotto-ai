{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability for the overlay window",
  "windows": ["overlay"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "sql:default"
  ]
}
